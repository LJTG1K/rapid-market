# ---------------------------------------------------------------------------
# Sugargoo instant signup (pages/api/sugargoo/register.ts, lib/sugargoo/tokenManager.ts)
# Required for the /signup page to create real accounts. Without these, the
# API returns a 500 "Server configuration error" and the form will not work.
# ---------------------------------------------------------------------------
SUGARGOO_API_BASE_URL=https://api.sugargoo.com/opencenter
SUGARGOO_API_USERNAME=your-sugargoo-account-username
SUGARGOO_API_PASSWORD=your-sugargoo-api-password

# Sugargoo invitation link shown as the fallback "Go to Sugargoo" URL.
# Update this monthly per PROJECT_SUMMARY.md — no redeploy needed if hosted
# on Vercel with env vars (pages/api/signup-url.ts reads it at request time).
SUGARGOO_SIGNUP_URL=https://www.sugargoo.com/auth/register?invite_code=XXXXX

# ---------------------------------------------------------------------------
# Google Sheets product feed (pages/api/products.ts)
# Powers /fashion-listings, /tech-listings, /brands, /gillys-picks and
# /product/[id]. Without these, every page falls back to a single demo
# product. See GOOGLE_SHEETS_SETUP.md for the expected sheet layout.
# ---------------------------------------------------------------------------
GOOGLE_SHEET_ID=1QJyne-Hqh91sWs_UMdyibKa1cN9Bt03E7imF-mZ-gbA
GOOGLE_API_KEY=your-google-cloud-api-key

# ---------------------------------------------------------------------------
# Facebook Lead Ads webhook (pages/api/facebook/webhook.ts)
# Auto-creates a Sugargoo account when a lead submits a Facebook lead form.
# ---------------------------------------------------------------------------
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
NEXT_PUBLIC_SITE_URL=https://rapid.market

# ---------------------------------------------------------------------------
# Google Analytics 4
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# Meta Pixel & Conversions API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_META_PIXEL_ID=951122617742977
META_CONVERSIONS_API_TOKEN=your-meta-access-token

# ---------------------------------------------------------------------------
# Supabase — persistent RAPID accounts + wishlist (lib/supabase.ts,
# lib/auth/*, pages/api/auth/*, pages/api/wishlist.ts)
# All DB access is server-side via the SERVICE-ROLE key, so the browser never
# talks to Supabase directly. Run the schema SQL from the plan first (users +
# wishlist_items tables). The anon key is not used by this feature.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — do NOT prefix with NEXT_PUBLIC_. Found in Supabase dashboard >
# Project Settings > API > service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Session signing secret (lib/auth/session.ts)
# HMAC key for the httpOnly session cookie. Server-only. Generate with e.g.
# `openssl rand -hex 32`. Rotating this invalidates all existing sessions.
# ---------------------------------------------------------------------------
SESSION_SECRET=your-long-random-session-secret

# ---------------------------------------------------------------------------
# Admin dashboard password (pages/api/admin/auth.ts)
# Server-only — do NOT prefix with NEXT_PUBLIC_, that would ship it to the
# browser bundle.
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=your-secure-password

# ---------------------------------------------------------------------------
# Telegram Notifications
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ---------------------------------------------------------------------------
# MailerLite (lib/mailerlite.ts)
# Captures the email at the moment of RAPID signup instead of waiting on
# Sugargoo's weekly export. Non-blocking — signup still succeeds if this
# fails or these are missing. Get the API key from MailerLite dashboard >
# Integrations > API. Group ID is read from GET /api/groups (or the
# dashboard's group settings) for the "RAPID_API_SIGNUPS" group.
# ---------------------------------------------------------------------------
MAILERLITE_API_KEY=your-mailerlite-api-key
MAILERLITE_GROUP_ID=your-mailerlite-group-id
